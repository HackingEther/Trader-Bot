# ── Core ──
APP_ENV=paper                          # local | paper | live
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-random-string

# ── Database ──
DATABASE_URL=postgresql+asyncpg://trader:trader@localhost:5432/trader
DATABASE_SYNC_URL=postgresql://trader:trader@localhost:5432/trader

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Broker: Alpaca ──
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# ── Market Data: Databento ──
MARKET_DATA_PROVIDER=databento          # databento | alpaca
MARKET_DATA_AUTOSTART=false
MARKET_DATA_SUBSCRIBE_BARS=true
MARKET_DATA_SUBSCRIBE_QUOTES=true
MARKET_DATA_SUBSCRIBE_TRADES=false
MARKET_DATA_STALENESS_THRESHOLD=30.0
DATABENTO_API_KEY=
DATABENTO_DATASET=XNAS.ITCH

# ── Market Data: Alpaca ──
ALPACA_DATA_FEED=iex                     # iex | sip

# ── Market Data: Polygon (stub) ──
POLYGON_API_KEY=

# ── Live Trading Safety ──
LIVE_TRADING=false
LIVE_TRADING_CONFIRMED=                # must equal "I_CONFIRM_LIVE_TRADING" to enable

# ── Risk Limits ──
MAX_DAILY_LOSS_USD=1000.0
MAX_LOSS_PER_TRADE_USD=200.0
MAX_NOTIONAL_EXPOSURE_USD=50000.0
MAX_CONCURRENT_POSITIONS=10
MAX_EXPOSURE_PER_SYMBOL_USD=10000.0
COOLDOWN_AFTER_LOSSES=3
SPREAD_THRESHOLD_BPS=50.0

# ── Strategy ──
SYMBOL_UNIVERSE=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,SPY,QQQ,AMD
MIN_CONFIDENCE=0.6
MIN_EXPECTED_MOVE_BPS=15.0
MIN_RELATIVE_VOLUME=0.8
MAX_SIGNALS_PER_CYCLE=3
LIMIT_ENTRY_BUFFER_BPS=5.0
OPEN_ORDER_STALE_SECONDS=90

# ── Notifications ──
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_TO=

# ── Observability ──
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ── Model Artifacts ──
ARTIFACTS_DIR=artifacts                  # mount this to persistent storage in hosted environments

# ── Admin ──
ADMIN_API_TOKEN=change-me-to-random-string

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
